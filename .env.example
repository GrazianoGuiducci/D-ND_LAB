# D-ND_LAB — environment configuration
#
# Copy this file to .env and fill in the values.
# Never commit .env (it is gitignored).

# ───────────────────────────────────────────────────────────────────
# LLM provider (OpenAI-compatible API)
# ───────────────────────────────────────────────────────────────────

# Provider selector — affects only docs/labels. Real choice is via base_url.
LLM_PROVIDER=openrouter

# Endpoint (OpenRouter recommended — 360+ models, no lock-in).
# Alternatives:
#   OpenAI:     https://api.openai.com/v1
#   Anthropic:  https://api.anthropic.com/v1   (compatibility shim)
#   Ollama:     http://localhost:11434/v1       (Phase 2.5 self-hosted)
LLM_BASE_URL=https://openrouter.ai/api/v1

# API key for the chosen endpoint.
LLM_API_KEY=

# Default model. Switch freely via this flag — no code changes required.
# Browse all available models with current pricing at:
#   https://openrouter.ai/models
#
# Common starting points (verify availability + cost on the page above):
#   deepseek/deepseek-v4-pro     — economy default, large context, tool calling
#   anthropic/claude-opus-4.7    — high quality, premium tier
#   tencent/hy3-preview:free     — free tier for dev/testing (rate-limited)
#   qwen/qwen3.5-plus-*          — fast + cheap, large context
#
# Pricing changes frequently. Always check live before committing to a tier.
LLM_MODEL=deepseek/deepseek-v4-pro

# Per-cycle hard limits (safety against runaway loops).
LLM_MAX_TURNS=25
LLM_TIMEOUT_SECONDS=1200

# ───────────────────────────────────────────────────────────────────
# Lab configuration
# ───────────────────────────────────────────────────────────────────

# Active domain. Must match a directory under domains/<name>/
LAB_DOMAIN=physics

# Where the lab persists state, reports, seed, cimitero.
# Inside Docker: /data
# Standalone: choose a directory under your home or /opt
LAB_DATA_DIR=/data

# Cron schedule for the nightly cycle (only used if cron mode enabled).
LAB_CRON_SCHEDULE="30 3 * * *"

# ───────────────────────────────────────────────────────────────────
# Optional integrations
# ───────────────────────────────────────────────────────────────────

# Notification webhook (Telegram bot, Discord webhook, custom HTTP).
# If empty, lab runs silently and only writes reports to disk.
NOTIFY_WEBHOOK_URL=

# MCP server URLs (Phase 2 — exposed tools as MCP). Comma-separated.
# Each server provides tools the lab agent can call.
# Example: MCP_SERVERS=http://localhost:8001/mcp,http://localhost:8002/mcp
MCP_SERVERS=

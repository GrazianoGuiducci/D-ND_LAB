# Secrets — mai committare
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv/
dist/
build/

# Lab runtime data — cycles produce volume, non va in git
data/
!domains/*/seed_tensions.json
!domains/*/config.json
!domains/*/context.md
!domains/*/tension_to_category.json

# Reports e log nightly — vivono nel volume Docker / nginx, non nel repo
domains/*/data/
domains/*/reports/
domains/*/cimitero.md
*.log

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Corpus privati (es. archivi insight operatore per Lab Editoriale).
# Use /* (not /) so exceptions for tracked placeholders work.
domains/*/corpus/*
!domains/*/corpus/.gitkeep
!domains/*/corpus/README.md

# ─────────────────────────────────────────────────────────────────
# Domain content vive in repo separate (refactor 03/05 sera).
# D-ND_LAB è l'engine; ogni dominio applicato è un repo a sé.
# Setup: clone il dominio dentro domains/<name>/ dopo install engine.
# ─────────────────────────────────────────────────────────────────
domains/physics/
# Experiment scripts del lab fisica (generati durante i cycles)
tools/exp_*.py

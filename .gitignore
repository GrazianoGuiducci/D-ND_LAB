# Secrets — mai committare
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.uv/
dist/
build/

# Lab runtime data — cycles produce volume, non va in git
data/
!domains/*/seed_tensions.json
!domains/*/config.json
!domains/*/context.md
!domains/*/tension_to_category.json

# Reports e log nightly — vivono nel volume Docker / nginx, non nel repo
domains/*/data/
domains/*/reports/
domains/*/cimitero.md
domains/_archive/**/cimitero.md
*.log

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Corpus privati (es. archivi insight operatore per Lab Editoriale).
# Use /* (not /) so exceptions for tracked placeholders work.
domains/*/corpus/*
!domains/*/corpus/.gitkeep
!domains/*/corpus/README.md

# Codex CLI marker file (0-byte sentinel scritto al primo run, non valore)
.codex

# Refiner output orfano in root (path corretto: data/<lab>/evolution/).
# Se appare in root, è output del refiner che ha confuso il working dir
# (es. codex --full-auto sandbox workspace-write con cwd=root). Pulizia.
/evolution_report.md
